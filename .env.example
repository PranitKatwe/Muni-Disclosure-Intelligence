# Copy to .env and fill in.

# LLM provider for extraction (M1+). Not needed for ingestion (M0) or tests.
# Option A (best quality): Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# Option B (free): NVIDIA Build hosted models - sign up at build.nvidia.com
# MUNI_LLM_PROVIDER=nvidia
# NVIDIA_API_KEY=nvapi-...
# MUNI_NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# Storage. SQLite by default; switch to Postgres (docker-compose.yml) later.
# MUNI_DATABASE_URL=sqlite:///data/muni.db
# MUNI_DATA_DIR=data

# Models
# MUNI_EXTRACTION_MODEL=claude-opus-4-8
# MUNI_TRANSLATION_MODEL=claude-sonnet-5
